# Kopieren nach .env und anpassen
SECRET_KEY=hier-einen-langen-zufaelligen-string-eintragen
INITIAL_ADMIN_PASSWORD=bitte-sofort-aendern
DATABASE_PATH=data/db.sqlite
SCHOOL_DOMAIN=befragung.meine-schule.de
# Optionales Schul-Logo (Pfad relativ zu static/)
# SCHOOL_LOGO=logo.png
# DSGVO-Hinweistext (kann leer bleiben)
DSGVO_HINWEIS=Diese Befragung ist vollständig anonym. Es werden keine personenbezogenen Daten gespeichert.
