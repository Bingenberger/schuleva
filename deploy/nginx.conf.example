server {
    listen 80;
    server_name befragung.meine-schule.de;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name befragung.meine-schule.de;

    ssl_certificate     /etc/letsencrypt/live/befragung.meine-schule.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/befragung.meine-schule.de/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Wichtig: kein access_log für POST-Body-Daten; TAN wird nie als URL-Parameter übergeben
    access_log /var/log/nginx/schulbefragung.access.log;
    error_log  /var/log/nginx/schulbefragung.error.log;

    client_max_body_size 2M;

    location /static/ {
        alias /opt/schulbefragung/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60;
    }
}
